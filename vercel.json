{
  "version": 2,
  "builds": [
    {
      "src": "web/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "web/dist",
        "installCommand": "cd web && npm install",
        "buildCommand": "cd web && npm run build"
      }
    }
  ],
  "outputDirectory": "web/dist",
  "routes": [
    { "src": "/(.*)", "dest": "/web/dist/$1" }
  ]
}
